# ============================================================================
# Professor Council — environment template
# Copy to ".env" and fill in. NEVER commit ".env" (it is git-ignored).
# Every value here is SERVER-SIDE ONLY. None of these may ship to the browser.
# ============================================================================

# ----- Relevance AI (required) ----------------------------------------------
# RELEVANCE_API_KEY: full project key, format "sk-...".
#   Dashboard > Settings > API Keys (project-level). Grants full project access.
RELEVANCE_API_KEY=
# RELEVANCE_REGION: one of  us | eu | au  (must match your project's region).
RELEVANCE_REGION=
# RELEVANCE_PROJECT_ID: your project id (Dashboard > Settings).
RELEVANCE_PROJECT_ID=

# Filled in later, as assets are built (leave blank for now):
RELEVANCE_COUNCIL_AGENT_ID=
# RELEVANCE_PROF_<SLUG>_AGENT_ID=

# ----- Transcription (pick ONE path; fill the matching key) ------------------
# Default/recommended: external AssemblyAI (handles long lectures, diarization).
ASSEMBLYAI_API_KEY=
# Only if using Relevance's native OpenAI audio->text model (60MB cap):
# OPENAI_API_KEY=
# Only if capturing lectures via Fireflies / a meeting tool:
# FIREFLIES_API_KEY=

# ----- Portal auth / gating (required for the portal) -----------------------
# PORTAL_TOKEN_SECRET: random 32+ char secret used to sign per-student links.
PORTAL_TOKEN_SECRET=
# PORTAL_SHARED_PASSWORD: optional coarse second factor (a single class password).
PORTAL_SHARED_PASSWORD=
# SESSION_SECRET: random secret used to sign portal session cookies.
SESSION_SECRET=

# ----- Portal config --------------------------------------------------------
# PORTAL_ALLOWED_ORIGIN: deployed portal origin, e.g. https://your-app.replit.app
PORTAL_ALLOWED_ORIGIN=
# Per-student daily message cap (worst-case credit protection):
PORTAL_MAX_MSGS_PER_STUDENT_PER_DAY=50
